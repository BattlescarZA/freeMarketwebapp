# Production Environment Variables
# Copy this to .env.production for production builds

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Polygon.io API
VITE_POLYGON_API_KEY=your-polygon-api-key

# App Configuration
VITE_APP_URL=https://vibefinance.vercel.app
VITE_APP_NAME=VibeFinance
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_USE_MOCK_DATA=false

# API Rate Limiting
VITE_API_RATE_LIMIT=5
VITE_API_RATE_WINDOW=60000
